{
  "expo": {
    "name": "Digital ABA Therapy",
    "slug": "aba-visual-performance",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/digital-aba-therapy-logo.png",
    "scheme": "abavisualperformance",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/digital-aba-therapy-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alinlolea.abavisualperformance"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/digital-aba-therapy-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/digital-aba-therapy-logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3725e06-8ec3-48fa-80ad-8053c61082ee"
      }
    }
  }
}
